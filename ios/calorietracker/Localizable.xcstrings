    },
    "You've hit today's usage limit. Try again tomorrow." : {
      "localizations" : {
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bạn đã đạt giới hạn sử dụng hôm nay. Hãy thử lại vào ngày mai."
