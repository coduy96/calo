    "Quit and reopen the app to apply the new language." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أغلق التطبيق وأعد فتحه لتطبيق اللغة الجديدة."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yeni dili tətbiq etmək üçün proqramı bağlayıb yenidən açın."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beende die App und öffne sie erneut, um die neue Sprache zu übernehmen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quit and reopen the app to apply the new language."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cierra la app y vuelve a abrirla para aplicar el nuevo idioma."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quittez l'application et relancez-la pour appliquer la nouvelle langue."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "नई भाषा लागू करने के लिए ऐप बंद करके फिर से खोलें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chiudi l'app e riaprila per applicare la nuova lingua."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しい言語を適用するには、アプリを終了して再度開いてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "새 언어를 적용하려면 앱을 종료한 뒤 다시 열어주세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sluit de app en open deze opnieuw om de nieuwe taal toe te passen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feche o app e abra-o novamente para aplicar o novo idioma."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Închide aplicația și redeschide-o pentru a aplica noua limbă."
