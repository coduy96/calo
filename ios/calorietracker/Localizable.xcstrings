    "Rate limit hit on your API key. Wait a minute, or switch to another provider in Settings → AI Provider." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم بلوغ حد الاستخدام لمفتاح API الخاص بك. انتظر دقيقة، أو بدّل المزود من الإعدادات ← مزود الذكاء الاصطناعي."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "API açarınızda limit aşıldı. Bir dəqiqə gözlə və ya Ayarlar → AI Təminatçısı bölümündən başqa təminatçıya keç."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Rate-Limit deines API-Schlüssels ist erreicht. Warte eine Minute oder wechsle in Einstellungen → KI-Anbieter zu einem anderen Anbieter."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rate limit hit on your API key. Wait a minute, or switch to another provider in Settings → AI Provider."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Has alcanzado el límite de tu clave API. Espera un minuto o cambia de proveedor en Ajustes → Proveedor de IA."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Limite de débit atteinte sur votre clé API. Attendez une minute ou changez de fournisseur dans Réglages → Fournisseur d'IA."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपकी API कुंजी की दर सीमा पूरी हो गई. एक मिनट प्रतीक्षा करें, या सेटिंग्स → AI प्रदाता में दूसरा प्रदाता चुनें."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Limite di chiamate raggiunto sulla tua chiave API. Attendi un minuto o cambia fornitore in Impostazioni → Fornitore IA."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "APIキーのレート制限に達しました。1分待つか、設定 → AIプロバイダ で別のプロバイダに切り替えてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "API 키의 속도 제한에 도달했어요. 잠시 기다리거나 설정 → AI 제공자에서 다른 제공자로 바꿔보세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je API-sleutel heeft de snelheidslimiet bereikt. Wacht een minuutje of schakel naar een andere provider via Instellingen → AI-provider."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Limite de uso atingido na sua chave API. Aguarde um minuto ou mude o provedor em Ajustes → Provedor de IA."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ai atins limita pe cheia API. Așteaptă un minut sau schimbă furnizorul în Setări → Furnizor AI."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Достигнут лимит запросов вашего API-ключа. Подождите минуту или выберите другого поставщика в Настройки → Поставщик ИИ."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "API key của bạn đã chạm giới hạn tốc độ. Hãy đợi một phút, hoặc đổi sang nhà cung cấp khác trong Cài đặt → Nhà cung cấp AI."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的 API 密钥已达速率限制。请稍等一分钟,或在“设置 → AI 提供商”中切换其他提供商。"
          }
        }
      }
    },
