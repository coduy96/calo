        }
      }
    },
    "You've reached your goal weight! Head to Settings to switch your goal (Maintain, Lose, or Gain) and tap Recalculate Goals to refresh your targets." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد وصلت إلى وزنك المستهدف! انتقل إلى الإعدادات لتبديل هدفك (الحفاظ، إنقاص، أو زيادة) ثم اضغط على إعادة حساب الأهداف لتحديث مقاييسك."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hədəf çəkinizə çatdınız! Hədəfinizi dəyişdirmək üçün Parametrlərə keçin (Saxla, Azalt və ya Artır) və hədəfləri yeniləmək üçün Hədəfləri Yenidən Hesabla düyməsinə toxunun."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du hast dein Zielgewicht erreicht! Gehe zu den Einstellungen, um dein Ziel zu ändern (Halten, Abnehmen oder Zunehmen), und tippe auf „Ziele neu berechnen“, um deine Zielwerte zu aktualisieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You've reached your goal weight! Head to Settings to switch your goal (Maintain, Lose, or Gain) and tap Recalculate Goals to refresh your targets."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Has alcanzado tu peso objetivo! Ve a Ajustes para cambiar tu objetivo (Mantener, Perder o Ganar) y toca Recalcular objetivos para actualizar tus metas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez atteint votre poids cible ! Allez dans Réglages pour changer d'objectif (Maintenir, Perdre ou Prendre) et appuyez sur Recalculer les objectifs pour actualiser vos cibles."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आप अपने लक्ष्य वजन तक पहुँच गए हैं! अपने लक्ष्य को बदलने के लिए (बनाए रखें, घटाएं या बढ़ाएं) सेटिंग्स पर जाएं और अपने लक्ष्य अपडेट करने के लिए लक्ष्य पुनः गणना करें पर टैप करें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hai raggiunto il peso obiettivo! Vai in Impostazioni per cambiare obiettivo (Mantieni, Perdi o Aumenta) e tocca Ricalcola obiettivi per aggiornare i tuoi target."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "目標体重に到達しました！設定で目標（維持、減量、増量）を切り替えて「目標を再計算」をタップし、ターゲットを更新してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "목표 체중에 도달했습니다! 설정에서 목표(유지, 감량 또는 증량)를 변경한 후 목표 다시 계산을 탭하여 목표치를 갱신하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je hebt je streefgewicht bereikt! Ga naar Instellingen om je doel te wijzigen (Behouden, Afvallen of Aankomen) en tik op Doelen opnieuw berekenen om je doelen bij te werken."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você atingiu seu peso-meta! Vá até Ajustes para mudar sua meta (Manter, Perder ou Ganhar) e toque em Recalcular metas para atualizar seus alvos."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ți-ai atins greutatea obiectiv! Mergi la Setări pentru a schimba obiectivul (Menține, Slăbește sau Câștigă) și atinge Recalculează obiectivele pentru a actualiza țintele."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы достигли целевого веса! Перейдите в Настройки, чтобы сменить цель (Поддержание, Снижение или Набор), и нажмите «Пересчитать цели», чтобы обновить показатели."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bạn đã đạt cân nặng mục tiêu! Vào Cài đặt để đổi mục tiêu (Duy trì, Giảm hoặc Tăng) rồi chạm Tính lại mục tiêu để làm mới các con số."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你已达到目标体重！前往“设置”切换目标（维持、减重或增重），然后点按“重新计算目标”以更新你的目标。"
          }
        }
      }
    },
