    "Right at maintenance. Show up daily; the rest takes care of itself." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تماماً عند الصيانة. احضر يومياً؛ والباقي يتولّى نفسه."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tam saxlama nöqtəsində. Hər gün gəl; qalanı öz-özünə həll olur."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Direkt auf Erhaltung. Täglich auftauchen — der Rest läuft."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Justo en mantenimiento. Aparece cada día; el resto se cuida solo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pile au maintien. Pointe-toi chaque jour ; le reste se règle tout seul."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "बिल्कुल मेंटेनेंस पर। रोज़ हाज़िर हों; बाकी अपने आप।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esatto al mantenimento. Presenti ogni giorno; il resto si arrangia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ちょうどメンテナンス。毎日顔を出せば、あとはついてくる。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "딱 유지선입니다. 매일 나타나세요. 나머지는 따라옵니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Precies op onderhoud. Daag dagelijks op; de rest gaat vanzelf."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bem na manutenção. Aparece todo dia; o resto se ajeita."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exact la menținere. Apari zilnic; restul se rezolvă singur."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Точно на поддержании. Появляйся каждый день — остальное само."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Đúng mức duy trì. Có mặt mỗi ngày; phần còn lại tự lo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "正好在维持线。每天都来一下，其余的自然成。"
          }
        }
      }
