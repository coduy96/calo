    "Your API key was rejected. Open Settings → AI Provider and re-paste a valid key." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم رفض مفتاح API الخاص بك. افتح الإعدادات ← مزود الذكاء الاصطناعي والصق مفتاحًا صالحًا."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "API açarınız qəbul edilmədi. Ayarlar → AI Təminatçısı bölümünü aç və düzgün açarı yenidən yapışdır."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein API-Schlüssel wurde abgelehnt. Öffne Einstellungen → KI-Anbieter und füge einen gültigen Schlüssel ein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your API key was rejected. Open Settings → AI Provider and re-paste a valid key."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu clave API fue rechazada. Abre Ajustes → Proveedor de IA y pega una clave válida."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre clé API a été rejetée. Ouvrez Réglages → Fournisseur d'IA et collez une clé valide."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपकी API कुंजी अस्वीकृत हो गई. सेटिंग्स → AI प्रदाता खोलें और एक मान्य कुंजी फिर से पेस्ट करें."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La tua chiave API è stata rifiutata. Apri Impostazioni → Fornitore IA e incolla una chiave valida."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "APIキーが拒否されました。設定 → AIプロバイダ を開き、有効なキーを貼り直してください。"
