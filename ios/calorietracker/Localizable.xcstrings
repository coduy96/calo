        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "API 키가 거부되었어요. 설정 → AI 제공자를 열고 유효한 키를 다시 붙여넣으세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je API-sleutel is geweigerd. Open Instellingen → AI-provider en plak een geldige sleutel."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sua chave API foi rejeitada. Abra Ajustes → Provedor de IA e cole uma chave válida."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cheia API a fost respinsă. Deschide Setări → Furnizor AI și lipește o cheie validă."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "API-ключ отклонён. Откройте Настройки → Поставщик ИИ и вставьте действующий ключ."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
