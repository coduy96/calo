    "Aggressive but doable. Requires strong discipline." : {
      "comment" : "A description of the fastest pace.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
