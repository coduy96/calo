    "Your logged calories and scale weight don't quite match. You may be under-logging food." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "السعرات الحرارية المسجلة ووزن الميزان لا يتطابقان تمامًا. قد تكون تسجل طعامًا أقل من الواقع."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qeyd etdiyiniz kalorilər və tərəzi çəkiniz tam uyğun gəlmir. Yeməyi az qeyd edə bilərsiniz."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine protokollierten Kalorien und dein Waagengewicht passen nicht ganz zusammen. Du protokollierst möglicherweise zu wenig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your logged calories and scale weight don't quite match. You may be under-logging food."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus calorías registradas y tu peso en la báscula no coinciden del todo. Puede que estés registrando menos comida de la que consumes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vos calories enregistrées et votre poids ne correspondent pas tout à fait. Vous sous-estimez peut-être vos apports."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपकी दर्ज की गई कैलोरी और तराज़ू का वज़न पूरी तरह मेल नहीं खाते। हो सकता है आप भोजन कम दर्ज कर रहे हों।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le calorie registrate e il peso sulla bilancia non corrispondono del tutto. Potresti registrare meno cibo del reale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "記録したカロリーと体重計の数値が一致していません。食事の記録が不足している可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기록한 칼로리와 체중계 수치가 완전히 일치하지 않습니다. 음식 기록이 부족할 수 있습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je gelogde calorieën en weeggewicht komen niet helemaal overeen. Mogelijk log je te weinig voedsel."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suas calorias registradas e o peso na balança não estão alinhados. Você pode estar registrando menos comida do que o real."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Caloriile înregistrate și greutatea de pe cântar nu se potrivesc complet. Poate înregistrezi mai puțină mâncare decât consumi."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Записанные калории и вес на весах не совсем совпадают. Возможно, вы записываете не всю еду."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calo bạn ghi và cân nặng trên cân hơi lệch nhau. Có thể bạn đang ghi thiếu món ăn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你记录的卡路里与体重秤读数不太吻合。你可能少记了一些食物。"
          }
        }
      }
    },
