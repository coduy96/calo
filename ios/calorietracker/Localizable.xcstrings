    "Keep your nutrition and body\nmeasurements in sync automatically." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حافظ على مزامنة تغذيتك\nوقياسات جسمك تلقائيًا."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
