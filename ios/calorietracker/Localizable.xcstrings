    "Remove %@'s entry of %@? This also deletes the matching sample from Apple Health." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل تريد حذف سجل %1$@ بقيمة %2$@؟ سيُحذف أيضًا العينة المطابقة من Apple Health."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ tarixli %2$@ qeydi silinsin? Apple Health-dəki uyğun nümunə də silinəcək."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eintrag von %1$@ mit %2$@ entfernen? Die zugehörige Probe in Apple Health wird ebenfalls gelöscht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remove %1$@'s entry of %2$@? This also deletes the matching sample from Apple Health."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Eliminar el registro de %1$@ con %2$@? También se borrará la muestra correspondiente de Apple Health."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supprimer l’entrée de %1$@ avec %2$@ ? L’échantillon correspondant sera également supprimé d’Apple Santé."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ की %2$@ की प्रविष्टि हटाएँ? Apple Health से मेल खाने वाला नमूना भी हट जाएगा."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rimuovere la voce del %1$@ con %2$@? Verrà eliminato anche il campione corrispondente da Apple Salute."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ の %2$@ の記録を削除しますか？ Apple ヘルスケア内の対応するサンプルも削除されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@의 %2$@ 기록을 삭제할까요? Apple 건강의 해당 샘플도 함께 삭제됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Item van %1$@ met %2$@ verwijderen? Het bijbehorende voorbeeld in Apple Gezondheid wordt ook verwijderd."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Excluir o registro de %1$@ com %2$@? A amostra correspondente também será removida do Apple Saúde."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ștergi intrarea din %1$@ de %2$@? Se va șterge și proba corespunzătoare din Apple Health."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Удалить запись от %1$@ со значением %2$@? Также будет удалена соответствующая запись из Apple Health."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Xoá mục ngày %1$@ với giá trị %2$@? Mẫu tương ứng trong Apple Health cũng sẽ bị xoá."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "删除 %1$@ 的 %2$@ 记录吗？同时会从“健康”中删除对应的样本。"
          }
        }
      }
    },
