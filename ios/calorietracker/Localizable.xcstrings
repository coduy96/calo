    "Skip it. Mifflin–St Jeor handles the math from your height, weight, and age." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تخطّ ذلك. ميفلين–سانت جيور يحسبها من طولك ووزنك وعمرك."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ötür. Mifflin–St Jeor boyun, çəkin və yaşına görə hesablayacaq."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Überspringen. Mifflin–St Jeor rechnet aus Größe, Gewicht und Alter."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sáltatelo. Mifflin–St Jeor calcula a partir de tu altura, peso y edad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passe. Mifflin–St Jeor fait le calcul depuis ta taille, ton poids et ton âge."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "छोड़ दें। Mifflin–St Jeor आपकी हाइट, वज़न और उम्र से हिसाब लगा लेगा।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salta. Mifflin–St Jeor calcola da altezza, peso ed età."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スキップ可。Mifflin–St Jeorが身長・体重・年齢から計算します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "건너뛰어도 됩니다. Mifflin–St Jeor가 키, 체중, 나이로 계산합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sla over. Mifflin–St Jeor rekent het uit lengte, gewicht en leeftijd."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pode pular. Mifflin–St Jeor calcula pela sua altura, peso e idade."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sari peste. Mifflin–St Jeor calculează din înălțime, greutate și vârstă."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пропусти. Mifflin–St Jeor посчитает по росту, весу и возрасту."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bỏ qua cũng được. Mifflin–St Jeor tính từ chiều cao, cân nặng và tuổi."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "可以跳过。Mifflin–St Jeor 会根据身高、体重和年龄计算。"
          }
        }
      }
    },
