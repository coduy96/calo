    "Steep. Doable if you stay strict — not for everyone." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حاد. ممكن إن التزمت — ليس للجميع."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sərt. Ciddi qalsan mümkündür — hər kəs üçün deyil."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Steil. Machbar, wenn du hart bleibst — nichts für jeden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Empinado. Posible si te mantienes estricto — no para todos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Raide. Faisable si tu restes strict — pas pour tout le monde."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "तीखा। सख़्त रहे तो हो सकता है — सबके लिए नहीं।"
