    "Fast enough to feel it. Slow enough to keep it." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سريع كفاية لتشعر به. بطيء كفاية لتحافظ عليه."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hiss edəcək qədər sürətli. Saxlayacaq qədər yavaş."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schnell genug, um es zu spüren. Langsam genug, um es zu halten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rápido para notarlo. Lento para mantenerlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assez vite pour le sentir. Assez lent pour le garder."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "महसूस होने जितना तेज़। बनाए रखने जितना धीमा।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abbastanza veloce da sentirlo. Abbastanza lento da tenerlo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "実感できる速さ。続けられる遅さ。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "느낄 만큼 빠르고, 유지할 만큼 느립니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snel genoeg om te voelen. Traag genoeg om te houden."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rápido o bastante para sentir. Lento o bastante para manter."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Destul de rapid să-l simți. Destul de lent să-l păstrezi."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Достаточно быстро, чтобы почувствовать. Достаточно медленно, чтобы удержать."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Đủ nhanh để cảm nhận. Đủ chậm để giữ được."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "够快让您感觉得到，够慢让您坚持得下去。"
          }
        }
      }
    },
