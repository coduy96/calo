    "Snap your meals. Talk to your coach.\nLet the data do the work." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "صوّر وجباتك. تحدّث مع مدرّبك.\nدع البيانات تتولّى المهمة."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yeməyini çək. Məşqçinlə danış.\nQoy işi məlumatlar görsün."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mahlzeit knipsen. Mit dem Coach reden.\nDie Daten machen den Rest."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foto a la comida. Habla con tu coach.\nDeja que los datos hagan lo suyo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Photographie tes repas. Parle à ton coach.\nLaisse les données bosser."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "खाने की फोटो लो। कोच से बात करो।\nबाकी डेटा संभाल लेगा।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scatta i pasti. Parla con il coach.\nLascia che siano i dati a lavorare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "食事を撮る。コーチと話す。\nあとはデータに任せて。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "식사를 찍어요. 코치와 이야기해요.\n나머지는 데이터가 처리합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maaltijden snappen. Praat met je coach.\nLaat de data het werk doen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fotografe as refeições. Fale com seu coach.\nDeixe os dados trabalharem."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pozează mesele. Vorbește cu coach-ul.\nLasă datele să facă treaba."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Снимай еду. Говори с тренером.\nДанные сделают остальное."
