    "Voidpen Plus is not active. Subscribe or switch back to Bring Your Own Key in Settings." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اشتراك Voidpen Plus غير مفعّل. اشترك أو ارجع إلى وضع \"استخدم مفتاحك الخاص\" من الإعدادات."
          }
        },
        "az" : {
          "stringUnit" : {
