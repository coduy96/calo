          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Een tekort van %lld cal — gekoppeld aan je TDEE, niet uit de lucht gegrepen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um déficit de %lld cal — atrelado ao seu TDEE, sem chute."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un deficit de %lld cal — ancorat la TDEE-ul tău, nu scos din pălărie."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дефицит %lld ккал — привязан к твоему TDEE, не с потолка."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
