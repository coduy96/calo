          "stringUnit" : {
            "state" : "translated",
            "value" : "현재 체중, 활동량, 목표를 기준으로 칼로리, 단백질, 탄수화물, 지방을 다시 계산하시겠습니까? 사용자 지정 값은 대체됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calorieën, eiwitten, koolhydraten en vetten opnieuw berekenen op basis van je huidige gewicht, activiteit en doel? Je aangepaste waarden worden vervangen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recalcular calorias, proteínas, carboidratos e gorduras com base no seu peso, atividade e meta atuais? Seus valores personalizados serão substituídos."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recalculezi caloriile, proteinele, carbohidrații și grăsimile pe baza greutății, activității și obiectivului actual? Valorile personalizate vor fi înlocuite."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пересчитать калории, белки, углеводы и жиры на основе текущего веса, активности и цели? Ваши пользовательские значения будут заменены."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tính lại calo, đạm, carb và chất béo dựa trên cân nặng, mức vận động và mục tiêu hiện tại? Các giá trị tuỳ chỉnh của bạn sẽ bị thay thế."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "根据你当前的体重、活动量和目标重新计算卡路里、蛋白质、碳水化合物和脂肪？你的自定义数值将被替换。"
          }
        }
      }
    },
    "Records up to 30 seconds of voice for meal logging." : {
