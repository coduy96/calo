    "Gentle and sustainable. Great for long-term habits." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خفيف ومستدام. مثالي للعادات طويلة الأمد."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mülayim və davamlı. Uzunmüddətli vərdişlər üçün ideal."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sanft und nachhaltig. Ideal für langfristige Gewohnheiten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suave y sostenible. Ideal para hábitos a largo plazo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doux et durable. Parfait pour des habitudes sur le long terme."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "हल्की और टिकाऊ रफ़्तार। लंबे समय की आदतों के लिए सबसे अच्छी।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Delicato e sostenibile. Perfetto per abitudini a lungo termine."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "穏やかで続けやすい。長く習慣にしたい人にぴったり。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "부드럽고 꾸준히 이어갈 수 있어요. 장기적인 습관 만들기에 좋아요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mild en vol te houden. Top voor langetermijngewoonten."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suave e sustentável. Ótimo para hábitos de longo prazo."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lent și sustenabil. Excelent pentru obiceiuri pe termen lung."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Мягкий и устойчивый темп. Отлично подходит для долгих привычек."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nhẹ nhàng và bền vững. Phù hợp để hình thành thói quen lâu dài."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "温和且可持续，适合养成长期习惯。"
          }
        }
      }
    },
    "Get gentle reminders at meal times\nso you never forget to track." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "احصل على تذكيرات لطيفة عند مواعيد الوجبات\nحتى لا تنسى التسجيل."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yemək vaxtlarında mülayim xatırlatmalar alın,\nqeyd etməyi unutmayın."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bekomme freundliche Erinnerungen zu den Mahlzeiten,\ndamit du das Tracken nicht vergisst."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recibe recordatorios amables a las horas de comida\npara no olvidar registrarlas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reçois des rappels en douceur aux heures des repas\npour ne jamais oublier de noter."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "हर भोजन के समय हल्के रिमाइंडर पाएँ\nताकि ट्रैक करना न भूलें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Promemoria gentili agli orari dei pasti,\nper non dimenticare di registrarli."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "食事の時間に優しくお知らせ。\n記録忘れを防ぎます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "식사 시간마다 부드럽게 알려드려요.\n기록을 잊지 않게 도와줘요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Krijg vriendelijke herinneringen bij maaltijden,\nzodat je niets vergeet vast te leggen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Receba lembretes amigáveis na hora das refeições\npara não esquecer de registrar."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Primești amintiri delicate la orele meselor,\nca să nu uiți să le înregistrezi."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Получай мягкие напоминания во время еды,\nчтобы не забыть всё записать."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nhận lời nhắc nhẹ nhàng vào giờ ăn\nđể không bỏ sót bữa nào."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用餐时温和提醒，\n再也不会忘记记录。"
          }
        }
      }
    },
