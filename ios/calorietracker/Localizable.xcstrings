    "Walk away and this resets." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اخرج وكل هذا يبدأ من جديد."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Çıxsan, hər şey sıfırlanır."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du gehst, fängt das von vorne an."
          }
