    "Save an API key for at least one other provider above, then come back to choose it as the fallback." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "احفظ مفتاح API لمزود آخر واحد على الأقل أعلاه، ثم عُد لاختياره كاحتياط."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yuxarıda ən azı bir başqa təminatçı üçün API açarı saxlayın, sonra geri qayıdıb onu ehtiyat kimi seçin."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Speichere einen API-Schlüssel für mindestens einen anderen Anbieter oben, dann komm zurück, um ihn als Fallback auszuwählen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Save an API key for at least one other provider above, then come back to choose it as the fallback."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Guarda una clave API para al menos otro proveedor arriba, luego regresa para elegirlo como respaldo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enregistrez une clé API pour au moins un autre fournisseur ci-dessus, puis revenez pour le choisir comme secours."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ऊपर कम से कम एक अन्य प्रदाता के लिए API कुंजी सहेजें, फिर इसे फ़ॉलबैक के रूप में चुनने के लिए वापस आएं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salva una chiave API per almeno un altro provider sopra, poi torna per sceglierlo come fallback."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "上記の他のプロバイダーの少なくとも1つのAPIキーを保存してから、フォールバックとして選択するために戻ってきてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "위에서 다른 제공업체에 대한 API 키를 하나 이상 저장한 다음 다시 와서 폴백으로 선택하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sla een API-sleutel op voor ten minste één andere aanbieder hierboven, kom dan terug om deze als fallback te kiezen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salve uma chave de API para pelo menos um outro provedor acima, depois volte para escolhê-lo como fallback."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salvează o cheie API pentru cel puțin un alt furnizor de mai sus, apoi revino pentru a-l alege ca rezervă."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сохраните API-ключ хотя бы для одного другого провайдера выше, затем вернитесь, чтобы выбрать его в качестве резерва."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lưu API key cho ít nhất một nhà cung cấp khác ở trên, rồi quay lại để chọn làm bản dự phòng."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请先在上方保存至少一个其他提供商的 API 密钥，然后返回此处将其选为备用方案。"
          }
        }
      }
    },
