    "Gain per week. Slow builds muscle, not fat." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "زيادة في الأسبوع. الأبطأ يبني عضل، لا دهن."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Həftəlik artım. Yavaş əzələ verir, yağ yox."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zunahme pro Woche. Langsam baut Muskeln, nicht Fett."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ganancia por semana. Lento gana músculo, no grasa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gain par semaine. Lent fait du muscle, pas du gras."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "हफ़्ते में बढ़ोतरी। धीमा मसल बनाता है, फैट नहीं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aumento a settimana. Lento costruisce muscolo, non grasso."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "週あたりの増量。ゆっくりは筋肉、速いと脂肪。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "주당 증량. 느릴수록 근육이 붙고 지방은 안 붙어요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toename per week. Traag bouwt spier op, geen vet."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ganho por semana. Devagar constrói músculo, não gordura."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Câștig pe săptămână. Încet construiește mușchi, nu grăsime."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прирост в неделю. Медленно — мышцы, быстро — жир."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tăng mỗi tuần. Chậm là cơ, nhanh là mỡ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每周增重。慢一点长肌肉，快了长脂肪。"
          }
        }
      }
    },
