    "Spend your motivation on the first four weeks. Aim a notch slower than your slider — it sticks." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنفق حماسك في الأسابيع الأربعة الأولى. صوّب درجة أبطأ من شريط التمرير — يثبت."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motivasiyanı ilk dörd həftəyə xərclə. Slayderdən bir pillə yavaş hədəflə — qalır."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Steck deine Motivation in die ersten vier Wochen. Ziel eine Stufe langsamer als der Slider — bleibt hängen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gasta tu motivación en las primeras cuatro semanas. Apunta una marca más lenta que el deslizador — se queda."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mets ta motivation dans les quatre premières semaines. Vise un cran plus lent que ton curseur — ça tient."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपनी मोटिवेशन पहले चार हफ़्तों में लगाएँ। स्लाइडर से एक नॉच धीमा रखें — टिकता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Investi la motivazione nelle prime quattro settimane. Punta una tacca più lento del cursore — resta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "モチベは最初の4週間に注ぐ。スライダーより一段ゆっくり狙う — 続く。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "동기는 첫 4주에 다 쏟으세요. 슬라이더보다 한 칸 느리게 잡으면 — 유지됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Steek je motivatie in de eerste vier weken. Mik één tandje trager dan je slider — dat blijft hangen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gaste sua motivação nas primeiras quatro semanas. Mire um nível mais devagar que o slider — fica."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cheltuie motivația în primele patru săptămâni. Țintește cu o crestătură mai încet decât glisorul — rămâne."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сожги мотивацию в первые четыре недели. Целься на одну ступень медленнее ползунка — закрепится."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dồn động lực vào bốn tuần đầu. Đặt thấp hơn thanh trượt một nấc — sẽ bền."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "把动力用在前四周。比滑块慢一档 — 才扎得住。"
          }
        }
      }
    },
