    "1,200 cal/day is the floor. Below that, get a professional in the loop." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1,200 سعرة/يوم هو الحد الأدنى. تحت ذلك، استشر مختصاً."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1.200 kalori/gün ən aşağı həddir. Daha az olarsa, mütəxəssis cəlb et."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1.200 kcal/Tag sind die Grenze. Drunter: hol dir Profis ins Boot."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1.200 cal/día es el mínimo. Por debajo, consulta a un profesional."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1 200 cal/jour, c'est le plancher. En dessous, prends un pro dans la boucle."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1,200 कैलोरी/दिन फ़्लोर है। उसके नीचे प्रोफ़ेशनल को साथ रखें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1.200 cal/giorno è il minimo. Sotto, coinvolgi un professionista."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1日1,200kcalが下限。それ以下なら専門家に相談を。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "하루 1,200 칼로리가 최저선이에요. 그 이하라면 전문가와 함께 하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1.200 cal/dag is de ondergrens. Daaronder: schakel een professional in."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1.200 cal/dia é o piso. Abaixo disso, envolva um profissional."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1.200 cal/zi e pragul minim. Sub asta, implică un profesionist."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1 200 ккал/день — нижний предел. Меньше — подключай специалиста."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1.200 calo/ngày là sàn. Thấp hơn thì hãy nhờ chuyên gia."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每日 1,200 卡是底线。低于此线，请专业人士介入。"
          }
        }
      }
    },
