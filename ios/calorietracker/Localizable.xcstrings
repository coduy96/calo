          }
        }
      }
    },
    "A %lld cal surplus. Hit your protein and most of it becomes muscle." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "فائض %lld سعرة. حقّق هدف البروتين ومعظمه يصير عضل."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld kalorilik artıq. Zülal hədəfini vur, çoxu əzələyə çevriləcək."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld kcal Überschuss. Triff dein Protein, dann wird's größtenteils Muskel."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un superávit de %lld cal. Cumple tu proteína y la mayoría será músculo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un surplus de %lld cal. Atteins tes protéines et la majeure partie devient du muscle."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld कैलोरी सरप्लस। प्रोटीन पूरा करें — ज़्यादातर मसल बनेगा।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un surplus di %lld cal. Centra le proteine e diventa quasi tutto muscolo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld kcalの余剰。タンパク質を満たせば、ほぼ筋肉になる。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 칼로리 잉여. 단백질만 챙기면 대부분 근육이 됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Een overschot van %lld cal. Haal je eiwit, en het meeste wordt spier."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um superávit de %lld cal. Bata a proteína e a maior parte vira músculo."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un surplus de %lld cal. Lovește proteina și mare parte devine mușchi."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Профицит %lld ккал. Добивай белок — большая часть уйдёт в мышцы."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thặng dư %lld calo. Đạt protein thì phần lớn thành cơ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
