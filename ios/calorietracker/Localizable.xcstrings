    "We'll keep your calories steady\nto maintain your current weight." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سنُبقي السعرات ثابتة\nللحفاظ على وزنك الحالي."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hazırkı çəkinizi qorumaq üçün\nkalorilərinizi sabit saxlayacağıq."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir halten deine Kalorien stabil,\ndamit dein Gewicht bleibt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantendremos las calorías estables\npara conservar tu peso actual."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous gardons tes calories stables\npour maintenir ton poids actuel."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "हम कैलोरी स्थिर रखेंगे ताकि\nआपका मौजूदा वज़न बना रहे।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manterremo le calorie costanti\nper farti restare al peso attuale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在の体重を維持できるよう、\nカロリーを一定に保ちます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "현재 체중을 유지할 수 있도록\n칼로리를 일정하게 유지해요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
