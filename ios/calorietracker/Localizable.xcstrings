    "Just snap, track, and thrive.\nYour nutrition, simplified." : {
      "comment" : "Welcome screen tagline below the headline. Keep both lines.",
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "صور، تتبّع، وازدهر.\nتغذيتك مبسطة."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bircə şəkil çək, izlə və inkişaf et.\nQidalanma sadələşdi."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einfach knipsen, tracken und durchstarten.\nErnährung, ganz einfach."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo haz una foto, registra y mejora.\nTu nutrición, simplificada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Photographie, suis tes apports et progresse.\nTa nutrition simplifiée."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "बस फ़ोटो लें, ट्रैक करें और बेहतर बनें।\nआपका पोषण, आसान बनाया गया।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scatta, registra e cresci.\nLa tua nutrizione, semplificata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "撮るだけで記録、そして前進。\n栄養管理をシンプルに。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "찍고, 기록하고, 더 건강하게.\n영양 관리를 단순하게."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foto maken, vastleggen en groeien.\nVoeding, vereenvoudigd."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tire a foto, registre e evolua.\nSua nutrição, simplificada."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fotografiezi, urmărești și progresezi.\nNutriția ta, simplificată."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сними, зафиксируй и расти.\nПитание — это просто."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chỉ cần chụp, ghi lại và bứt phá.\nDinh dưỡng, gọn nhẹ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "拍一拍、记一记、变得更好。\n你的营养，从此简单。"
          }
        }
      }
    },
