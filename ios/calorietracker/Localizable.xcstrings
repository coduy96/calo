    "Surplus plus lifting equals muscle. Without lifting it's just fat. Track protein." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "فائض + رفع = عضل. بدون رفع، مجرد دهن. تتبّع البروتين."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Artıq + qaldırma = əzələ. Qaldırmasan, sadəcə yağ. Zülalı izlə."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Überschuss + Training = Muskel. Ohne Training nur Fett. Protein tracken."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Superávit más pesas igual a músculo. Sin pesas, solo grasa. Registra la proteína."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Surplus + muscu = muscle. Sans muscu, c'est du gras. Track le protéine."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सरप्लस + वेट लिफ़्टिंग = मसल। बिना लिफ़्टिंग ये सिर्फ़ फैट है। प्रोटीन ट्रैक करें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Surplus più sollevamento uguale muscolo. Senza pesi è solo grasso. Traccia le proteine."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "余剰＋筋トレ＝筋肉。筋トレなしならただの脂肪。タンパク質を記録。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "잉여 + 웨이트 = 근육. 웨이트 없으면 그냥 지방. 단백질 추적하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overschot plus heffen is spier. Zonder heffen is het gewoon vet. Track eiwit."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Superávit mais musculação é igual a músculo. Sem treino é só gordura. Acompanhe a proteína."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Surplus plus haltere egal mușchi. Fără haltere e doar grăsime. Urmărește proteina."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Профицит плюс тренировки — мышцы. Без тренировок — просто жир. Считай белок."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thặng dư cộng tập tạ ra cơ. Không tập, chỉ là mỡ. Theo dõi protein."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "盈余加举铁等于肌肉。不举铁就只是脂肪。盯紧蛋白质。"
          }
        }
      }
    },
