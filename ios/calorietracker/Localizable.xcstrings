          "stringUnit" : {
            "state" : "translated",
            "value" : "Voidpen द्वारा किसी तृतीय-पक्ष AI प्रदाता को डेटा भेजने से पहले, हमें आपकी अनुमति चाहिए।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
