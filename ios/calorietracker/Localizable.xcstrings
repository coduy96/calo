    "Coach exceeded the tool-call round limit. Try rephrasing your question." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تجاوز المدرب الحد الأقصى لعدد استدعاءات الأدوات. حاول إعادة صياغة سؤالك."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Məşqçi vasitə çağırışı limitini keçdi. Sualını başqa cür ifadə etməyə çalış."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Coach hat das Limit für Tool-Aufrufe überschritten. Formuliere deine Frage am besten neu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coach exceeded the tool-call round limit. Try rephrasing your question."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El Coach superó el límite de llamadas a herramientas. Intenta reformular tu pregunta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le Coach a dépassé la limite d'appels aux outils. Essayez de reformuler votre question."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कोच टूल-कॉल राउंड सीमा से अधिक हो गया. कृपया अपना प्रश्न दोबारा लिखें."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il Coach ha superato il limite di chiamate agli strumenti. Prova a riformulare la domanda."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "コーチがツール呼び出しの上限を超えました。質問の言い回しを変えてみてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "코치가 도구 호출 한도를 초과했어요. 질문을 다시 표현해 보세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coach heeft de limiet voor toolaanroepen overschreden. Probeer je vraag anders te stellen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Coach excedeu o limite de chamadas a ferramentas. Tente reformular sua pergunta."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Antrenorul a depășit limita de apeluri la unelte. Reformulează întrebarea."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тренер превысил лимит вызовов инструментов. Попробуйте переформулировать вопрос."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coach đã vượt giới hạn gọi công cụ. Hãy thử diễn đạt lại câu hỏi."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "教练已超出工具调用次数上限。请尝试换一种问法。"
          }
        }
      }
    },
