        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld कैलोरी का डेफ़िसिट — आपके TDEE से जुड़ा, हवा में नहीं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un deficit di %lld cal — ancorato al tuo TDEE, non a caso."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld kcalの不足 — TDEEに紐づけ。当てずっぽうじゃない。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
