    "Describe what you ate. We'll stop when you do." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "صف ما أكلت. سنتوقف حين تتوقف."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nə yediyini təsvir et. Sən dayananda biz də dayanacağıq."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beschreib, was du gegessen hast. Wir stoppen, wenn du fertig bist."
          }
        },
